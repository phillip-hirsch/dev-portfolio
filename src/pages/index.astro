---
import EducationSection from '../components/organisms/EducationSection/EducationSection.astro'
import ExperienceSection from '../components/organisms/ExperienceSection/ExperienceSection.astro'
import Hero from '../components/organisms/Hero/Hero.astro'
import SkillsSection from '../components/organisms/SkillsSection/SkillsSection.astro'
import portrait from '../images/portrait.jpg'
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Phillip Hirsch | Software Engineer"
  description="Software engineer building accessible, performant web and mobile products with React, TypeScript, and modern architecture."
>
  <main class="w-full mx-auto px-6 lg:px-10">
    <!-- Hero -->
    <div class="min-h-[calc(100dvh-4.5rem)] flex flex-col justify-center">
      <Hero
        name="Phillip Hirsch"
        image={portrait}
        imageAlt="Phillip Hirsch smiling in a plaid button-up shirt and a white t-shirt"
      />
    </div>

    <!-- Below-fold sections -->
    <div class="max-w-250 mx-auto flex flex-col gap-24 pb-28 lg:gap-32">
      <ExperienceSection />
      <EducationSection />
      <SkillsSection />
    </div>
  </main>
</BaseLayout>
