---
import Hero from '../components/Hero/Hero.astro'
import portrait from '../images/portrait.jpg'
import BaseLayout from '../layouts/BaseLayout.astro'
import { pageTransition } from '../utils/animations'

const techStack = ['React', 'TypeScript', 'React Native', 'Node.js', 'GraphQL']

const featuredWork = [
  {
    title: 'Enterprise Mobile Performance',
    description:
      'Reduced app load times by 15% and improved rendering efficiency by 30% through state and component architecture improvements.',
    href: '/experience/',
    cta: 'View Experience',
  },
  {
    title: 'Accessible Product Delivery',
    description:
      'Drove WCAG 2.1 improvements and reusable UI patterns across multiple production applications with stronger DX and consistency.',
    href: '/about/',
    cta: 'Read About',
  },
  {
    title: 'Code Craft & Collaboration',
    description:
      'Built scalable React and TypeScript systems while mentoring teammates and reducing onboarding friction across shared codebases.',
    href: 'https://github.com/phillip-hirsch',
    cta: 'Visit GitHub',
    external: true,
  },
]
---

<BaseLayout
  title="Phillip Hirsch | Frontend Engineer"
  description="Frontend engineer building accessible, performant web and mobile products with React, TypeScript, and modern architecture."
>
  <main class="mx-auto px-6 pb-24 lg:px-10" transition:animate={pageTransition}>
    <Hero
      name="Phillip Hirsch"
      image={portrait}
      imageAlt="Phillip Hirsch smiling in a plaid button-up shirt and a white t-shirt"
      techStack={techStack}
    />

    <section class="mx-auto mt-18 max-w-6xl animate-[fadeInUp_0.55s_ease-out_backwards] [animation-delay:300ms]">
      <div class="mb-8 flex items-center gap-3 lg:mb-10">
        <span class="h-px w-8 bg-accent-regular"></span>
        <p class="font-brand text-[0.72rem] uppercase tracking-[0.16em] text-accent-regular">
          Featured Work
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 lg:grid-cols-3 lg:gap-5">
        {
          featuredWork.map((item, index) => (
            <article
              class="group relative overflow-hidden rounded-2xl border border-gray-800 bg-(image:--gradient-subtle) p-6 shadow-sm transition-[transform,border-color,box-shadow] duration-200 hover:-translate-y-0.5 hover:border-accent-regular/50 hover:shadow-md"
              style={`animation-delay: ${0.38 + index * 0.08}s`}
            >
              <div
                class="pointer-events-none absolute inset-x-0 top-0 h-px opacity-80"
                style={{ background: 'var(--gradient-accent)' }}
                aria-hidden="true"
              ></div>
              <h2 class="m-0 font-brand text-[clamp(1.1rem,2vw,1.35rem)] text-gray-0">
                {item.title}
              </h2>
              <p class="mt-3 text-sm leading-[1.75] text-gray-300">
                {item.description}
              </p>
              <a
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noreferrer' : undefined}
                class="mt-6 inline-flex items-center gap-2 font-brand text-sm text-accent-regular no-underline transition-colors duration-200 hover:text-accent-dark"
              >
                {item.cta}
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
