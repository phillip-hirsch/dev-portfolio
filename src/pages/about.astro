---
import PageHeader from '../components/PageHeader/PageHeader.astro'
import SectionHeader from '../components/SectionHeader/SectionHeader.astro'
import { aboutSummary, educationEntries, skillCategories } from '../data/about'
import BaseLayout from '../layouts/BaseLayout.astro'
import { pageTransition } from '../utils/animations'

const skillRowClass =
  'grid grid-cols-1 gap-[0.4rem] border-b border-gray-800 py-[1.1rem] transition-colors duration-150 lg:grid-cols-[11rem_1fr] lg:items-baseline lg:gap-8 lg:py-4 lg:hover:-mx-6 lg:hover:rounded-md lg:hover:border-t-transparent lg:hover:border-b-transparent lg:hover:bg-(--color-accent-subtle-overlay) lg:hover:px-6'
---

<BaseLayout title="About | Phillip Hirsch" description="About Phillip Hirsch">
  <main
    class="max-w-250 mx-auto flex flex-col gap-24 px-6 py-8 pb-28 lg:gap-32"
    transition:animate={pageTransition}
  >
    <PageHeader title="About Me" align="start" />

    <!-- Summary -->
    <section
      class="flex flex-col gap-8 animate-[fadeInUp_0.5s_ease-out_backwards]"
      style="animation-delay: 0.05s"
    >
      <SectionHeader label="Overview" title="Summary" />
      <div
        class="relative pl-6 before:absolute before:bottom-[0.2em] before:left-0 before:top-[0.2em] before:w-0.75 before:rounded-xs before:[background:var(--gradient-accent)] before:content-['']"
      >
        <p
          class="max-w-[70ch] text-[clamp(1rem,1.8vw,1.15rem)] leading-[1.9] text-gray-200"
        >
          {aboutSummary}
        </p>
      </div>
    </section>

    <!-- Education -->
    <section
      class="flex flex-col gap-8 animate-[fadeInUp_0.5s_ease-out_backwards]"
      style="animation-delay: 0.15s"
    >
      <SectionHeader label="Background" title="Education" />

      <ol
        class="relative m-0 list-none pl-4 before:absolute before:bottom-[0.6rem] before:left-0 before:top-[0.6rem] before:w-px before:bg-[linear-gradient(to_bottom,var(--color-accent-regular),transparent)] before:content-['']"
        role="list"
      >
        {
          educationEntries.map((entry) => (
            <li class="group relative flex gap-6 border-b border-gray-800 py-7 last:border-b-0 last:pb-0">
              <div
                class="absolute -left-5.5 top-9 flex items-center justify-center"
                aria-hidden="true"
              >
                <span
                  class="block h-2.5 w-2.5 rounded-full bg-accent-regular shadow-[0_0_0_3px_var(--color-gray-999),0_0_0_5px_var(--color-accent-regular)] transition-shadow duration-200 group-hover:shadow-[0_0_0_3px_var(--color-gray-999),0_0_0_5px_var(--color-accent-regular),0_0_12px_var(--color-accent-overlay)]"
                ></span>
              </div>
              <article class="flex flex-col gap-[0.4rem] pl-2">
                <div
                  class="flex flex-col gap-[0.15rem] lg:flex-row lg:items-baseline lg:gap-4"
                >
                  <time
                    class="font-brand text-[0.75rem] font-bold uppercase tracking-widest text-accent-regular"
                    datetime={entry.dateTime}
                  >
                    {entry.dateLabel}
                  </time>
                  <span class="text-[0.825rem] text-gray-400">
                    {entry.institution}
                  </span>
                </div>
                <h3
                  class="m-0 font-brand text-[clamp(1.05rem,2.5vw,1.3rem)] font-semibold leading-[1.2] text-gray-0"
                >
                  {entry.degree}
                </h3>
                <p class="m-0 text-[0.825rem] italic text-gray-400">
                  Concentration: {entry.concentration}
                </p>
              </article>
            </li>
          ))
        }
      </ol>
    </section>

    <!-- Skills -->
    <section
      class="flex flex-col gap-8 animate-[fadeInUp_0.5s_ease-out_backwards]"
      style="animation-delay: 0.25s"
    >
      <SectionHeader label="Expertise" title="Skills" />

      <dl class="flex flex-col">
        {
          skillCategories.map((category, index) => (
            <div class={`${skillRowClass} ${index === 0 ? 'border-t' : ''}`}>
              <dt
                class="whitespace-nowrap font-brand text-[0.725rem] font-bold uppercase tracking-widest text-accent-regular"
              >
                {category.label}
              </dt>
              <dd class="text-[0.9rem] leading-[1.7] text-gray-300">
                {category.items.join(' \u00b7 ')}
              </dd>
            </div>
          ))
        }
      </dl>
    </section>
  </main>
</BaseLayout>
