---
// Learn about using Astro layouts:
// https://docs.astro.build/en/basics/layouts/

// Component Imports
import MainHead from '../components/MainHead/MainHead.astro'
import Nav from '../components/organisms/Nav/Nav.astro'

interface Props {
  title?: string | undefined
  description?: string | undefined
}

const { title, description } = Astro.props
---

<html lang="en">
  <head>
    <MainHead title={title} description={description} />
  </head>
  <body class="flex flex-col min-h-dvh backgrounds">
    <Nav />
    <slot />
  </body>
</html>

<script is:inline>
	const getThemePreference = () => {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
	};
	const isDark = getThemePreference() === 'dark';
	document.documentElement.classList[isDark ? 'add' : 'remove']('dark');

	if (typeof localStorage !== 'undefined') {
		// Uses `let` because `lastStoredTheme` is updated inside the MutationObserver callback.
		let lastStoredTheme = localStorage.getItem('theme');
		const observer = new MutationObserver(() => {
			const isDark = document.documentElement.classList.contains('dark');
			const nextTheme = isDark ? 'dark' : 'light';
			if (lastStoredTheme !== nextTheme) {
				localStorage.setItem('theme', nextTheme);
				lastStoredTheme = nextTheme;
			}
		});
		observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
	}

	// Scroll-triggered reveal animations
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	if (!prefersReducedMotion) {
		const revealObserver = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						entry.target.classList.add('revealed');
						revealObserver.unobserve(entry.target);
					}
				}
			},
			{ threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
		);
		document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
	} else {
		// If reduced motion, show everything immediately
		document.querySelectorAll('.reveal').forEach((el) => el.classList.add('revealed'));
	}
</script>
