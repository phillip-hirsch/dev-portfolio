---
import type { SkillCategory } from '../../../data/skills'

interface Props {
  category: SkillCategory
  isFirst?: boolean
}
const { category, isFirst = false } = Astro.props

const rowClass =
  'skill-row grid grid-cols-1 gap-[0.4rem] border-b border-gray-800/30 py-[1.1rem] transition-all duration-300 ease-out lg:grid-cols-[11rem_1fr] lg:items-baseline lg:gap-8 lg:py-4 lg:hover:-mx-6 lg:hover:rounded-xl lg:hover:border-t-transparent lg:hover:border-b-transparent lg:hover:px-6'
---

<div class={`${rowClass} ${isFirst ? 'border-t border-gray-800/30' : ''}`}>
  <dt
    class="whitespace-nowrap font-brand text-[0.725rem] font-bold uppercase tracking-widest text-accent-regular"
  >
    {category.label}
  </dt>
  <dd class="text-[0.9rem] leading-[1.7] text-gray-300">
    {category.items.join(' · ')}
  </dd>
</div>

<style>
  @media (min-width: 50em) {
    .skill-row:hover {
      background: var(--chip-bg);
    }
  }
</style>
