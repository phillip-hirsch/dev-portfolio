---
interface Props {
  label: string
  title: string
}

const { label, title } = Astro.props
---

<header
  class="relative flex flex-col gap-[0.3rem] overflow-hidden pb-5"
>
  <p
    class="m-0 font-body text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-accent-regular"
  >
    {label}
  </p>
  <h2
    class="m-0 font-brand text-[clamp(1.6rem,4vw,2.4rem)] font-semibold text-gray-0"
  >
    {title}
  </h2>
  <div
    class="mt-3 h-px w-full bg-[linear-gradient(to_right,var(--color-accent-regular),var(--color-accent-light)_40%,transparent_80%)]"
    aria-hidden="true"
  >
  </div>
</header>
