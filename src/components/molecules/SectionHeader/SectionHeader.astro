---
interface Props {
  label: string
  title: string
}

const { label, title } = Astro.props
---

<header
  class="relative flex flex-col gap-[0.3rem] overflow-hidden pb-5"
>
  <span
    class="font-body text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-accent-regular"
  >
    {label}
  </span>
  <h2
    class="m-0 font-brand text-[clamp(1.6rem,4vw,2.4rem)] font-semibold leading-[1.1] text-gray-0"
  >
    {title}
  </h2>
  <div
    class="mt-3 h-px w-full"
    style="background: linear-gradient(to right, var(--color-accent-regular), var(--color-accent-light) 40%, transparent 80%);"
    aria-hidden="true"
  >
  </div>
</header>
