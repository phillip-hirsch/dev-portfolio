---
import type { EducationEntry as EducationEntryType } from '../../../data/education'
import TimelineDot from '../../atoms/TimelineDot/TimelineDot.astro'

interface Props {
  entry: EducationEntryType
}
const { entry } = Astro.props
---

<li class="group relative flex gap-6 border-b border-gray-800/30 py-7 last:border-b-0 last:pb-0">
  <div class="absolute -left-5.5 top-9 flex items-center justify-center" aria-hidden="true">
    <TimelineDot size="sm" />
  </div>
  <article class="flex flex-col gap-[0.4rem] pl-2">
    <div class="flex flex-col gap-[0.15rem] lg:flex-row lg:items-baseline lg:gap-4">
      <time
        class="font-brand text-[0.75rem] font-bold uppercase tracking-widest text-accent-regular"
        datetime={entry.dateTime}
      >
        {entry.dateLabel}
      </time>
      <span class="text-[0.825rem] text-gray-400">{entry.institution}</span>
    </div>
    <h3
      class="m-0 font-brand text-[clamp(1.05rem,2.5vw,1.3rem)] font-semibold leading-[1.2] text-gray-0"
    >
      {entry.degree}
    </h3>
    <p class="m-0 text-[0.825rem] italic text-gray-400">
      Concentration: {entry.concentration}
    </p>
  </article>
</li>
