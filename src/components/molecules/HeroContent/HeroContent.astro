---
import { DownloadSimpleIcon } from '@phosphor-icons/react'
import ButtonLink from '../../atoms/ButtonLink/ButtonLink.astro'
import PillList from '../PillList/PillList.astro'

interface Props {
  firstName: string
  lastName: string
  techStack: string[]
}
const { firstName, lastName, techStack } = Astro.props
---

<div
  class="order-2 lg:order-1 flex flex-col gap-5 items-center lg:items-start animate-[fadeInUp_0.5s_ease-out_backwards] [animation-delay:200ms]"
>
  <h1
    class="flex flex-col font-brand font-semibold leading-none tracking-tight text-center lg:text-start"
  >
    <span class="text-[clamp(2.5rem,5.5vw,5rem)] text-gray-0">{firstName}</span>
    {
      lastName && (
        <span class="text-[clamp(2.5rem,5.5vw,5rem)] bg-(image:--gradient-accent) bg-clip-text text-transparent">
          {lastName}
        </span>
      )
    }
  </h1>

  <div class="flex items-center gap-3">
    <div class="w-5 h-px bg-accent-regular shrink-0 hidden lg:block"></div>
    <p class="text-xs text-gray-300 uppercase tracking-[0.14em]">
      Software Engineer · Charlotte, NC · 3+ Years
    </p>
  </div>

  <PillList items={techStack} size="sm" ariaLabel="Core technologies" />

  <p class="text-sm leading-relaxed text-gray-200 text-center lg:text-start max-w-sm">
    I turn complex requirements into clean, scalable products — specializing in React, TypeScript,
    and the full stack between design and deployment.
  </p>

  <div class="flex flex-wrap items-center gap-3 justify-center lg:justify-start">
    <ButtonLink href="/assets/Phillip_Hirsch.pdf" variant="secondary" download={true}>
      <DownloadSimpleIcon size={14} aria-hidden="true" className="shrink-0" />
      Resume
    </ButtonLink>
  </div>
</div>
