---
interface Props {
  href: string
  variant?: 'primary' | 'secondary'
  download?: boolean
}
const { href, variant = 'primary', download } = Astro.props
---

{
  variant === 'primary' ? (
    <a
      href={href}
      download={download || undefined}
      class="bg-accent-regular focus-visible:outline-accent-regular hover:bg-accent-dark inline-flex w-fit items-center gap-2 rounded-2xl px-5 py-2.5 text-sm font-medium text-white no-underline transition-all duration-300 ease-out focus-visible:outline-2 focus-visible:outline-offset-2"
      style="box-shadow: inset 0 1px 0 0 hsla(0,0%,100%,0.25), 0 4px 16px hsla(199,89%,48%,0.2);"
    >
      <slot />
    </a>
  ) : (
    <a
      href={href}
      download={download || undefined}
      class="chip focus-visible:outline-accent-regular inline-flex w-fit items-center gap-2 rounded-2xl px-5 py-2.5 text-sm font-medium text-gray-300 no-underline transition-all duration-300 ease-out hover:text-gray-100 focus-visible:outline-2 focus-visible:outline-offset-2"
    >
      <slot />
    </a>
  )
}
