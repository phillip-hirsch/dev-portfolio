---
interface Props {
  href: string
  variant?: 'primary' | 'secondary'
  download?: boolean
}
const { href, variant = 'primary', download } = Astro.props
---

{
  variant === 'primary' ? (
    <a
      href={href}
      download={download || undefined}
      class="no-underline w-fit inline-flex items-center gap-2 px-5 py-2.5 rounded-2xl text-sm font-medium bg-accent-regular text-white transition-all duration-300 ease-out focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-regular hover:bg-accent-dark"
      style="box-shadow: inset 0 1px 0 0 hsla(0,0%,100%,0.25), 0 4px 16px hsla(199,89%,48%,0.2);"
    >
      <slot />
    </a>
  ) : (
    <a
      href={href}
      download={download || undefined}
      class="chip no-underline w-fit inline-flex items-center gap-2 px-5 py-2.5 rounded-2xl text-sm font-medium text-gray-300 transition-all duration-300 ease-out focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-regular hover:text-gray-100"
    >
      <slot />
    </a>
  )
}
