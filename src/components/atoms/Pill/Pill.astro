---
interface Props {
  size?: 'sm' | 'md'
}
const { size = 'md' } = Astro.props
const sizeClasses =
  size === 'sm'
    ? 'font-mono text-[0.7rem] py-[0.3rem] px-[0.75rem] tracking-[0.02em] select-none'
    : 'text-xs font-medium px-3.5 py-1.5'
---

<span
  class={`glass-chip rounded-full text-gray-300 cursor-default hover:text-gray-100 ${sizeClasses}`}
>
  <slot />
</span>
