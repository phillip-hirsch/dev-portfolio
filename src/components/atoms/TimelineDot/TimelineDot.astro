---
interface Props {
  size?: 'sm' | 'lg'
}
const { size = 'sm' } = Astro.props
---

{
  size === 'sm' ? (
    <span class="bg-accent-regular block size-2.5 rounded-full shadow-[0_0_0_3px_var(--color-gray-999),0_0_0_5px_var(--color-accent-regular)] transition-shadow duration-200 group-hover:shadow-[0_0_0_3px_var(--color-gray-999),0_0_0_5px_var(--color-accent-regular),0_0_12px_var(--color-accent-overlay)]" />
  ) : (
    <span class="border-accent-regular block size-5 rounded-full border-2 bg-(--color-gray-999) shadow-[0_0_0_4px_var(--color-gray-999),0_0_12px_var(--color-accent-overlay)]" />
  )
}
