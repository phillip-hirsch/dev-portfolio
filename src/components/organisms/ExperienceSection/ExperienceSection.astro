---
import { experiences } from '../../../data/experience'
import GradientDivider from '../../atoms/GradientDivider/GradientDivider.astro'
import TimelineDot from '../../atoms/TimelineDot/TimelineDot.astro'
import AccomplishmentGroup from '../../molecules/AccomplishmentGroup/AccomplishmentGroup.astro'
import ExperienceCardHeader from '../../molecules/ExperienceCardHeader/ExperienceCardHeader.astro'
import SectionHeader from '../../molecules/SectionHeader/SectionHeader.astro'
---

<section
  id="experience"
  class="relative flex flex-col gap-10 lg:before:absolute lg:before:bottom-3 lg:before:-left-6 lg:before:top-3 lg:before:w-0.5 lg:before:rounded-[1px] lg:before:bg-[linear-gradient(to_bottom,var(--color-accent-regular),var(--color-accent-light)_60%,transparent)] lg:before:content-['']"
>
  <div class="reveal">
    <SectionHeader label="Career" title="Experience" />
  </div>

  {
    experiences.map((experience, entryIndex) => (
      <article
        class={`reveal reveal-delay-${Math.min(entryIndex + 1, 4)} liquid-glass relative flex flex-col gap-6 rounded-[1.5rem] p-8 lg:p-10`}
      >
        <div class="hidden lg:block absolute -left-8.5 top-8" aria-hidden="true">
          <TimelineDot size="lg" />
        </div>

        <ExperienceCardHeader
          title={experience.title}
          employmentType={experience.employmentType}
          company={experience.company}
          via={experience.via}
          period={experience.period}
          location={experience.location}
          technologies={experience.technologies}
        />

        <GradientDivider />

        <div class="flex flex-col gap-6">
          {experience.categories.map((category) => (
            <AccomplishmentGroup category={category} />
          ))}
        </div>
      </article>
    ))
  }
</section>
