---
import { textLinks } from '../../../data/nav'

interface Props {
  variant: 'desktop' | 'mobile'
}
const { variant } = Astro.props
---

{
  variant === 'desktop' ? (
    <ul class="m-0 flex list-none gap-1 p-0" role="list">
      {textLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            {...(href === '/' ? { 'data-nav-home': true } : {})}
            class="desktop-nav-link hover:text-gray-0 relative inline-flex items-center rounded-xl px-4 py-1.5 text-sm font-medium text-gray-400 no-underline transition-all duration-300"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <ul class="m-0 flex list-none flex-col p-0" role="list">
      {textLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            {...(href === '/' ? { 'data-nav-home': true } : {})}
            class="hover:text-accent-regular flex w-full items-center px-6 py-4 text-lg font-medium text-gray-100 no-underline transition-colors duration-200 active:bg-gray-900"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .desktop-nav-link:hover {
    background: var(--chip-bg);
  }
</style>
