---
import { textLinks } from '../../../data/nav'

interface Props {
  variant: 'desktop' | 'mobile'
}
const { variant } = Astro.props
---

{
  variant === 'desktop' ? (
    <ul class="m-0 flex list-none gap-1 p-0" role="list">
      {textLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            {...(href === '/' ? { 'data-nav-home': true } : {})}
            class="desktop-nav-link relative inline-flex items-center no-underline font-medium px-4 py-1.5 text-sm rounded-xl text-gray-400 transition-all duration-300 hover:text-gray-0"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <ul class="m-0 flex flex-col list-none p-0" role="list">
      {textLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            {...(href === '/' ? { 'data-nav-home': true } : {})}
            class="flex items-center no-underline font-medium w-full px-6 py-4 text-lg text-gray-100 transition-colors duration-200 hover:text-accent-regular active:bg-gray-900"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .desktop-nav-link:hover {
    background: var(--glass-chip-bg);
    box-shadow: var(--glass-chip-specular);
  }
</style>
